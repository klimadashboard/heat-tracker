# Heat threshold in °C — above this a grid cell is counted as "affected".
# This sets the server-side default; the UI lets users override it at runtime.
HEAT_THRESHOLD=30

# Server port (default: 3000)
PORT=3000

# Optional: proxy /api requests to a remote server during local development.
# Useful if you don't have a local DB but want to develop against live data.
# Example: API_PROXY=https://heat-tracker.eu
# API_PROXY=
